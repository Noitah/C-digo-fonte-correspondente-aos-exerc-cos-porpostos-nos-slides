@model IEnumerable<Academico.Models.Curso>

@{
    ViewData["Title"] = "Cursos";
}

<h1>Cursos</h1>

<p>
    <a asp-action="Create">Criar Novo</a>
</p>
<table class="table">
    <thead>
        <tr>
            <th>Nome</th>
            <th>Carga Horária</th>
            <th>Departamento</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@Html.DisplayFor(modelItem => item.Nome)</td>
                <td>@Html.DisplayFor(modelItem => item.CargaHoraria)</td>
                <td>@Html.DisplayFor(modelItem => item.Departamento.Nome)</td>
                <td>
                    <a asp-action="Edit" asp-route-id="@item.CursoID">Edit</a> |
                    <a asp-action="Details" asp-route-id="@item.CursoID">Details</a> |
                    <a asp-action="Delete" asp-route-id="@item.CursoID">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>

@model IEnumerable<Academico.Models.Instituicao>

@{
    ViewData["Title"] = "Instituições";
}

<h1>Instituições</h1>

<p>
    <a asp-action="Create">Criar Nova</a>
</p>
<table class="table">
    <thead>
        <tr>
            <th>Nome</th>
            <th>Endereço</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@Html.DisplayFor(modelItem => item.Nome)</td>
                <td>@Html.DisplayFor(modelItem => item.Endereco)</td>
                <td>
                    <a asp-action="Edit" asp-route-id="@item.InstituicaoID">Edit</a> |
                    <a asp-action="Details" asp-route-id="@item.InstituicaoID">Details</a> |
                    <a asp-action="Delete" asp-route-id="@item.InstituicaoID">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>

@model Academico.Models.Instituicao

@{
    ViewData["Title"] = "Detalhes da Instituição";
}

<h1>Detalhes da Instituição</h1>

<div>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">Nome</dt>
        <dd class="col-sm-10">@Model.Nome</dd>
        <dt class="col-sm-2">Endereço</dt>

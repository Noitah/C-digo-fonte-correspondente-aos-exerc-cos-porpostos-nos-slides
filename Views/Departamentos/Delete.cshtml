@model Academico.Models.Departamento

@{
    ViewData["Title"] = "Excluir Departamento";
}

<h1>Excluir Departamento</h1>

<h3>Tem certeza que deseja excluir?</h3>
<div>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">Nome</dt>
        <dd class="col-sm-10">@Model.Nome</dd>
        <dt class="col-sm-2">Instituição</dt>
        <dd class="col-sm-10">@Model.Instituicao.Nome</dd>
    </dl>

    <form asp-action="Delete">
        <input type="hidden" asp-for="DepartamentoID" />
        <input type="submit" value="Delete" class="btn btn-danger" /> |
        <a asp-action="Index">Back to List</a>
    </form>
</div>

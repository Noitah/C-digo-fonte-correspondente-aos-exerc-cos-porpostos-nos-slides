@model Academico.Models.Departamento

@{
    ViewData["Title"] = "Detalhes do Departamento";
}

<h1>Detalhes do Departamento</h1>

<div>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">Nome</dt>
        <dd class="col-sm-10">@Model.Nome</dd>
        <dt class="col-sm-2">Instituição</dt>
        <dd class="col-sm-10">@Model.Instituicao.Nome</dd>
    </dl>
</div>
<div>
    <a asp-action="Edit" asp-route-id="@Model.DepartamentoID">Edit</a> |
    <a asp-action="Index">Back to List</a>
</div>
